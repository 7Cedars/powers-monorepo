# XMTP Agent SDK Configuration
XMTP_WALLET_KEY=0x... # Bot's Ethereum private key
XMTP_DB_ENCRYPTION_KEY=0x... # 32-byte hex for database encryption (generate with: openssl rand -hex 32)
XMTP_DB_DIRECTORY=/app/data # Railway volume mount path (use ./data for local development)
XMTP_ENV=production # Options: dev, production

# Alchemy RPC URLs (for viem contract watching)
ALCHEMY_API_KEY_SEPOLIA=https://eth-sepolia.g.alchemy.com/v2/YOUR_KEY

# Optional: Additional chains for future expansion
# ALCHEMY_API_KEY_BASE_SEPOLIA=https://base-sepolia.g.alchemy.com/v2/YOUR_KEY
# ALCHEMY_API_KEY_OPTIMISM_SEPOLIA=https://opt-sepolia.g.alchemy.com/v2/YOUR_KEY
# ALCHEMY_API_KEY_ARBITRUM_SEPOLIA=https://arb-sepolia.g.alchemy.com/v2/YOUR_KEY

# API Server Configuration
PORT=3001
NODE_ENV=production

# API Security (optional - for create-group endpoint authentication)
API_SECRET_KEY=your_secret_key_here

# Powers Contract Addresses (comma-separated Ethereum addresses)
POWERS_ADDRESSES=0x1234567890123456789012345678901234567890,0x0987654321098765432109876543210987654321
